{
  "name": "retrobasic-wasm",
  "version": "0.1.0",
  "description": "An isomorphic WebAssembly (WASM) port of the RetroBASIC interpreter. Execute legacy BASIC code seamlessly in both Node.js and browser environments.",
  "type": "module",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minhqdao/basicade.git",
    "directory": "packages/retrobasic-wasm"
  },
  "homepage": "https://github.com/minhqdao/basicade/tree/main/packages/retrobasic-wasm#readme",
  "bugs": {
    "url": "https://github.com/minhqdao/basicade/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "wasm",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:wasm": "bash ./scripts/build-wasm.sh",
    "test": "echo \"Integration test runs from root: npm run test:integration\"",
    "prepublishOnly": "npm run build:wasm && npm run build && npm run test"
  },
  "keywords": [
    "basic",
    "retrobasic",
    "wasm",
    "webassembly",
    "emscripten",
    "compiler",
    "interpreter",
    "emulator",
    "retro",
    "retro-gaming",
    "vintage-computing"
  ]
}
