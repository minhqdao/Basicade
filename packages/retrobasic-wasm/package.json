{
  "name": "retrobasic-wasm",
  "version": "0.1.1",
  "description": "Run classic BASIC programs in Node.js and the browser, powered by a WebAssembly build of RetroBASIC.",
  "type": "module",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minhqdao/Basicade.git",
    "directory": "packages/retrobasic-wasm"
  },
  "homepage": "https://github.com/minhqdao/Basicade/tree/main/packages/retrobasic-wasm#readme",
  "bugs": {
    "url": "https://github.com/minhqdao/Basicade/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc && tsup",
    "build:wasm": "bash ./scripts/build-wasm.sh",
    "test": "npm run test:run-basic && npm run test:echo",
    "test:echo": "node test/echo.mjs",
    "test:run-basic": "node test/run-basic.mjs",
    "prepublishOnly": "npm run build:wasm && npm run build && npm run test"
  },
  "keywords": [
    "basic",
    "retrobasic",
    "wasm",
    "webassembly",
    "interpreter",
    "ms-basic",
    "lex",
    "yacc",
    "emulator",
    "retro"
  ]
}
