{
  "name": "bwbasic-wasm",
  "version": "0.1.1",
  "description": "Run legacy BASIC programs in Node.js and the browser, powered by a WebAssembly build of Bywater BASIC.",
  "type": "module",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minhqdao/Basicade.git",
    "directory": "packages/bwbasic-wasm"
  },
  "homepage": "https://github.com/minhqdao/Basicade/tree/main/packages/bwbasic-wasm#readme",
  "bugs": {
    "url": "https://github.com/minhqdao/Basicade/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc && tsup",
    "build:wasm": "bash ./scripts/build-wasm.sh",
    "test": "npm run test:run-basic && npm run test:clk",
    "test:clk": "node test/clk.mjs",
    "test:run-basic": "node test/run-basic.mjs",
    "prepublishOnly": "npm run build:wasm && npm run build && npm run test"
  },
  "keywords": [
    "basic",
    "bwbasic",
    "bywater-basic",
    "ansi-basic",
    "wasm",
    "webassembly",
    "interpreter",
    "emulator",
    "retro",
    "oregon-trail"
  ]
}
