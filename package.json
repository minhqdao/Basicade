{
  "name": "bwbasic-wasm",
  "version": "0.1.0",
  "description": "WebAssembly build of the Bywater BASIC interpreter.",
  "type": "module",
  "license": "GPL-2.0-only",
  "files": [
    "dist",
    "wasm",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:wasm": "bash ./scripts/build-wasm.sh",
    "prepublishOnly": "npm run build:wasm && npm run build",
    "dev": "vite --open /demo/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && tsc --noEmit"
  },
  "keywords": [
    "basic",
    "bywater-basic",
    "wasm",
    "webassembly",
    "interpreter",
    "retro",
    "oregon-trail"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
